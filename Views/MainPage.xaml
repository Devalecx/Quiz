<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoftwareEngineeringQuizApp.Views.MainPage"
             xmlns:vm="clr-namespace:SoftwareEngineeringQuizApp.ViewModels"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#4B0082">
    <VerticalStackLayout
        Spacing="25"
        Padding="30,0"
        VerticalOptions="Center">

        <Label
            Text="SOFTWARE ENGINEERING"
            SemanticProperties.HeadingLevel="Level1"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="White"
            HorizontalOptions="Center" />

        <Label
            Text="Quiz"
            FontSize="48"
            FontAttributes="Bold"
            TextColor="Gold"
            HorizontalOptions="Center" />

        <Button
            Text="Empezar Quiz"
            Command="{Binding GoToQuizCommand}"
            BackgroundColor="DodgerBlue"
            TextColor="White"
            HeightRequest="50"
            CornerRadius="25"/>

        <Button
            Text="Flashcards"
            Command="{Binding GoToFlashcardsCommand}"
            BackgroundColor="Tomato"
            TextColor="White"
            HeightRequest="50"
            CornerRadius="25"/>
    </VerticalStackLayout>
</ContentPage>