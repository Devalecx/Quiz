<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SoftwareEngineeringQuizApp.Views.TopicSelectionPage"
             xmlns:vm="clr-namespace:SoftwareEngineeringQuizApp.ViewModels"
             xmlns:models="clr-namespace:SoftwareEngineeringQuizApp.Models"
             x:DataType="vm:TopicSelectionViewModel"
             Title="Selecciona un Tema"
             BackgroundColor="#4B0082">

    <Grid>
        <!-- ✅ NUEVO: Indicador de carga -->
        <ActivityIndicator 
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            Color="White"
            VerticalOptions="Center"
            HorizontalOptions="Center" />

        <!-- ✅ NUEVO: Mensaje de error -->
        <VerticalStackLayout 
            IsVisible="{Binding HasError}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Padding="20">
            <Label 
                Text="{Binding ErrorMessage}"
                TextColor="White"
                FontSize="18"
                HorizontalTextAlignment="Center"/>
            <Button 
                Text="Reintentar"
                Command="{Binding LoadTopicsCommand}"
                BackgroundColor="DodgerBlue"
                TextColor="White"
                Margin="0,20,0,0"/>
        </VerticalStackLayout>

        <!-- Contenido principal -->
        <ScrollView IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="15" Padding="20">
                <Label 
                    Text="Selecciona un Tema"
                    TextColor="White"
                    FontSize="24"
                    FontAttributes="Bold"
                    HorizontalOptions="Center" />

                <CollectionView ItemsSource="{Binding Topics}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Topic">
                            <Frame Padding="20" 
                                   CornerRadius="15" 
                                   BackgroundColor="#F0F0F0" 
                                   Margin="0,5"
                                   HasShadow="True">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TopicSelectionViewModel}}, Path=SelectTopicCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>

                                <VerticalStackLayout Spacing="5">
                                    <Label 
                                        Text="{Binding Name}" 
                                        FontSize="20" 
                                        FontAttributes="Bold"
                                        TextColor="#4B0082" />
                                    <Label 
                                        Text="{Binding Description}" 
                                        FontSize="14" 
                                        TextColor="#666666" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>