<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoftwareEngineeringQuizApp.ViewModels"
             x:Class="SoftwareEngineeringQuizApp.Views.PreguntaQuizPage"
             Title="{Binding TemaActual}"
             BackgroundColor="#704193"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <vm:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView Margin="0,60,0,0">
            <VerticalStackLayout Padding="30" Spacing="20">

                <Label Text="{Binding TextoProgreso}" 
                       HorizontalOptions="Center" 
                       TextColor="Yellow" 
                       FontSize="16"/>

                <Frame BackgroundColor="White" 
                       CornerRadius="15" 
                       Padding="20" 
                       HasShadow="True" 
                       BorderColor="#512BD4">
                    <Label Text="{Binding PreguntaActual.Pregunta}" 
                           FontSize="20" 
                           HorizontalTextAlignment="Center" 
                           TextColor="#333" 
                           FontAttributes="Bold"/>
                </Frame>

                <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>

                <StackLayout BindableLayout.ItemsSource="{Binding PreguntaActual.Opciones}" 
                             Spacing="15">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Button Text="{Binding .}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PreguntaQuizViewModel}}, Path=ResponderCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="25"
                                    HeightRequest="60"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:PreguntaQuizViewModel}}, Path=BotonesHabilitados}"
                                    Shadow="{Shadow Brush=Black, Offset='2,2', Opacity=0.2}">

                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:PreguntaQuizViewModel}}, Path=MostrarFeedback}"
                                                 Value="False">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                        <Setter Property="TextColor" Value="#000000"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

                <Frame IsVisible="{Binding MostrarFeedback}"
                       CornerRadius="15"
                       Padding="20"
                       HasShadow="True"
                       Margin="0,20,0,0">

                    <Frame.Triggers>
                        <DataTrigger TargetType="Frame"
                                     Binding="{Binding EsRespuestaCorrecta}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#E8F5E9"/>
                            <Setter Property="BorderColor" Value="#4CAF50"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Frame"
                                     Binding="{Binding EsRespuestaCorrecta}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                            <Setter Property="BorderColor" Value="#F44336"/>
                        </DataTrigger>
                    </Frame.Triggers>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="{Binding MensajeFeedback}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding EsRespuestaCorrecta}"
                                             Value="True">
                                    <Setter Property="TextColor" Value="#2E7D32"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding EsRespuestaCorrecta}"
                                             Value="False">
                                    <Setter Property="TextColor" Value="#C62828"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <BoxView HeightRequest="1" Color="LightGray"/>

                        <Label Text="Explicación:"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333"/>

                        <Label Text="{Binding ExplicacionFeedback}"
                               FontSize="14"
                               TextColor="#555"
                               LineBreakMode="WordWrap"/>

                        <Button Text="Siguiente Pregunta"
                                Command="{Binding SiguientePreguntaCommand}"
                                BackgroundColor="#512BD4"
                                TextColor="White"
                                CornerRadius="20"
                                HeightRequest="50"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <Button Text="☰"
                Command="{Binding AbrirMenuCommand}"
                FontSize="24"
                TextColor="White"
                BackgroundColor="#704193"
                BorderColor="White"
                BorderWidth="1"
                CornerRadius="10"
                HeightRequest="50"
                WidthRequest="50"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="20,20,20,0"
                Padding="0"
                ZIndex="10"/>

        <Grid IsVisible="{Binding MenuVisible}" 
              ZIndex="20" 
              BackgroundColor="#CC000000">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CerrarMenuCommand}"/>
            </Grid.GestureRecognizers>

            <Frame BackgroundColor="White"
                   CornerRadius="20"
                   WidthRequest="300"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Padding="25"
                   HasShadow="True">

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer />
                </Frame.GestureRecognizers>

                <VerticalStackLayout Spacing="20">
                    <Label Text="Configuración" 
                           TextColor="#520D60" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

                    <BoxView HeightRequest="2" 
                             Color="#E0E0E0" 
                             HorizontalOptions="FillAndExpand"/>

                    <HorizontalStackLayout Spacing="15">
                        <Image Source="musica.png"
                               HeightRequest="24"
                               WidthRequest="24"
                               VerticalOptions="Center"/>

                        <Label Text="Música de Fondo" 
                               VerticalOptions="Center" 
                               FontSize="16" 
                               TextColor="#333"
                               HorizontalOptions="StartAndExpand"/>
                        <Switch IsToggled="{Binding IsMusicEnabled}" 
                                OnColor="#17C3B2"
                                ThumbColor="White"
                                VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15">
                        <Image Source="sonido.png"
                               HeightRequest="24"
                               WidthRequest="24"
                               VerticalOptions="Center"/>

                        <Label Text="Efectos de Sonido" 
                               VerticalOptions="Center" 
                               FontSize="16" 
                               TextColor="#333"
                               HorizontalOptions="StartAndExpand"/>
                        <Switch IsToggled="{Binding IsSoundEffectsEnabled}" 
                                OnColor="#17C3B2"
                                ThumbColor="White"
                                VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="2" 
                             Color="#E0E0E0" 
                             HorizontalOptions="FillAndExpand"
                             Margin="0,10"/>

                    <Button Text="Salir al Menú Principal" 
                            Command="{Binding SalirAlMenuCommand}"
                            BackgroundColor="#F44336"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            FontSize="15"
                            FontAttributes="Bold"/>

                    <Button Text="Cancelar" 
                            Command="{Binding CerrarMenuCommand}"
                            BackgroundColor="#E0E0E0"
                            TextColor="#333"
                            CornerRadius="12"
                            HeightRequest="50"
                            FontSize="15"
                            FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>