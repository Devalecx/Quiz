<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoftwareEngineeringQuizApp.ViewModels"
             x:Class="SoftwareEngineeringQuizApp.Views.MenuPrincipalPage"
             Title="Menú Principal"
             BackgroundColor="#704193"
             Shell.NavBarIsVisible="False">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0" 
                             HorizontalOptions="Start" 
                             Spacing="5">

            <Border Stroke="White"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 40"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center"
                    BackgroundColor="#9C27B0">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding IrAPerfilCommand}"/>
                </Border.GestureRecognizers>

                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.3" Radius="3"/>
                </Border.Shadow>

                <Grid>
                    <Grid.Clip>
                        <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40" />
                    </Grid.Clip>

                    <Image Source="{Binding FotoPerfil}" 
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill"/>
                </Grid>
            </Border>

            <Label Text="Perfil"
                   TextColor="White"
                   FontSize="14"
                   FontAttributes="Bold"
                   HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding IrAPerfilCommand}"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>


        <VerticalStackLayout Grid.Row="1" 
                             Spacing="20" 
                             VerticalOptions="Start" 
                             Margin="0,20,0,0">

            <Image Source="principal.png"
                   WidthRequest="280"
                   HeightRequest="280"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center" 
                                   Spacing="10" 
                                   Margin="0,-10,0,20">

                <Label Text="{Binding NombreUsuario, StringFormat='¡BIENVENIDO, {0}!'}"
                       TextColor="#FFD700"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.Shadow>
                        <Shadow Brush="Black" Offset="2,2" Opacity="0.5"/>
                    </Label.Shadow>
                </Label>

                <Image Source="fiesta.png"
                       HeightRequest="32"
                       WidthRequest="32"
                       VerticalOptions="Center"
                       Aspect="AspectFit"/>

            </HorizontalStackLayout>

            <VerticalStackLayout Spacing="25">
                <Button Text="Iniciar Quiz"
                        Command="{Binding IrAQuizCommand}"
                        BackgroundColor="#00C853"
                        TextColor="White"
                        HeightRequest="90"
                        CornerRadius="15"
                        FontSize="22"
                        FontAttributes="Bold"
                        Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.3}"/>

                <Button Text="Estudiar Flashcards"
                        Command="{Binding IrAFlashcardsCommand}"
                        BackgroundColor="#FF5252"
                        TextColor="White"
                        HeightRequest="90"
                        CornerRadius="15"
                        FontSize="22"
                        FontAttributes="Bold"
                        Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.3}"/>
            </VerticalStackLayout>
        </VerticalStackLayout>

    </Grid>
</ContentPage>