<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SoftwareEngineeringQuizApp.ViewModels"
             xmlns:models="clr-namespace:SoftwareEngineeringQuizApp.Models"
             x:Class="SoftwareEngineeringQuizApp.Views.ListaTemasQuizPage"
             Title="Selecciona un Tema"
             BackgroundColor="#704193">
    <!-- 1. FONDO ACTUALIZADO -->

    <Grid>
        <!-- Indicador de Carga -->
        <!-- 2. Color cambiado a White -->
        <ActivityIndicator IsRunning="{Binding EstaCargando}" 
                           IsVisible="{Binding EstaCargando}"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           Color="White"
                           ZIndex="2"/>

        <!-- Lista de Temas con Iconos -->
        <CollectionView ItemsSource="{Binding TemasUI}"
                        SelectionMode="None"
                        Margin="20">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TemaUI">
                    <!-- Las tarjetas se quedan blancas para contrastar con el fondo morado -->
                    <Frame CornerRadius="12" HasShadow="True" BorderColor="Transparent" Padding="15" BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListaTemasQuizViewModel}}, Path=SeleccionarTemaCommand}"
                                                  CommandParameter="{Binding Nombre}"/>
                        </Frame.GestureRecognizers>

                        <HorizontalStackLayout Spacing="20" VerticalOptions="Center">

                            <!-- IMAGEN (Izquierda) -->
                            <Image Source="{Binding IconoSource}"
                                   WidthRequest="45"
                                   HeightRequest="45"
                                   Aspect="AspectFit"
                                   VerticalOptions="Center"/>

                            <!-- TEXTO (Derecha) -->
                            <Label Text="{Binding Nombre}" 
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#333" 
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>