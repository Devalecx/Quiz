<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SoftwareEngineeringQuizApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SoftwareEngineeringQuizApp.Views"
    Title="Software Engineering Quiz"
    FlyoutBehavior="Disabled"
    BackgroundColor="#704193"
    Shell.ForegroundColor="White" 
    Shell.TitleColor="White">

    <Shell.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#704193</Color>
            <Style x:Key="BaseStyle" TargetType="Element">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.ForegroundColor" Value="White" />
                <Setter Property="Shell.TitleColor" Value="White" />
                <Setter Property="Shell.DisabledColor" Value="#B4FFFFFF" />
                <Setter Property="Shell.UnselectedColor" Value="#95FFFFFF" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <ShellContent
        Title="Inicio"
        ContentTemplate="{DataTemplate views:MenuPrincipalPage}"
        Route="MenuPrincipal" />

</Shell>